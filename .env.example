# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# IA - Provedor ativo: gemini | groq | anthropic | openrouter
AI_PROVIDER=gemini

# Google Gemini (gratuito: 15 req/min, 1M tokens/dia)
# Obter em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (gratuito: 14.400 req/dia - llama-3.3-70b)
# Obter em: https://console.groq.com/keys
GROQ_API_KEY=

# Anthropic Claude (pago)
# Obter em: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenRouter (créditos gratuitos iniciais)
# Obter em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Pagamentos (configurar na Fase 7)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Assinatura Eletrônica
CLICKSIGN_API_TOKEN=
ZAPSIGN_API_TOKEN=
GOVBR_CLIENT_ID=
GOVBR_CLIENT_SECRET=
GOVBR_REDIRECT_URI=https://app.licitaia.com.br/api/assinatura/govbr/callback

# Rate limiting (Upstash Redis)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin master da plataforma: este e-mail recebe papel admin_plataforma automaticamente no onboarding
ADMIN_PLATFORM_EMAIL=
